library ieee;
    use ieee.std_logic_1164.all;
    use ieee.numeric_std.all;

entity video_dac is
    port(
        clock       : in  std_logic;
        enable      : in  std_logic;
        color       : in  std_logic_vector(1 downto 0);
        attr        : in  std_logic_vector(7 downto 0);
        blank       : in  std_logic;
        pixel       : in  std_logic;
        blink_clock : in  std_logic;                        -- 1Hz blink clock
        rgb         : out std_logic_vector(11 downto 0)
    );
end video_dac;

architecture behavior of video_dac is

    -- convert 4-bit RGBI to 12-bit RGB (board ordering: 11..8=B 7..4=G 3..0=R)
    function rgbi_to_rgb(rgbi : std_logic_vector(3 downto 0)) return std_logic_vector is
        variable i : std_logic;
        variable r : std_logic_vector(3 downto 0);
        variable g : std_logic_vector(3 downto 0);
        variable b : std_logic_vector(3 downto 0);
    begin
        i := rgbi(0);
        if    rgbi(3) = '1' and i = '1' then r := x"F";
        elsif rgbi(3) = '1'             then r := x"7";
        else                                 r := x"0";
        end if;
        if    rgbi(2) = '1' and i = '1' then g := x"F";
        elsif rgbi(2) = '1'             then g := x"7";
        else                                 g := x"0";
        end if;
        if    rgbi(1) = '1' and i = '1' then b := x"F";
        elsif rgbi(1) = '1'             then b := x"7";
        else                                 b := x"0";
        end if;
        return r & g & b;
    end function;

    signal col_fg  : std_logic_vector(3 downto 0);
    signal col_bg  : std_logic_vector(3 downto 0);
    signal reverse : std_logic;                             -- reverese flag: col_data(0)
    signal blink   : std_logic;                             -- blink flag: col_data(1) AND blink_clock
    signal px      : std_logic;                             -- pixel after blink inversion (mono modes)
    signal rgb_reg : std_logic_vector(11 downto 0);

begin
    col_fg  <= attr(3 downto 0);                        -- foreground RGBI (color mode)
    col_bg  <= attr(7 downto 4);                        -- background RGBI (color mode)
    reverse <= attr(0);
    blink   <= attr(1) and blink_clock;                 -- blink active when attribute set AND clock high
    -- in mono modes blink inverts pixel (fg/bg swap = phosphor swap)
--    px <= pixel xor blink;
--    px <=  pixel xor reverse xor blink when attr(1) = '1' and color /= "11" else pixel;

    px <= pixel                         when color = "11" else
          pixel xor reverse xor blink;

    rgb_reg <= x"0F0"              when (enable = '1') and (blank = '0') and (color = "00") and (px = '1') else  -- green phosphor
               x"FA0"              when (enable = '1') and (blank = '0') and (color = "01") and (px = '1') else  -- amber phosphor
               x"FFF"              when (enable = '1') and (blank = '0') and (color = "10") and (px = '1') else  -- white phosphor
               rgbi_to_rgb(col_fg) when (enable = '1') and (blank = '0') and (color = "11") and (px = '1') else  -- color fg (after reverse+blink)
               rgbi_to_rgb(col_bg) when (enable = '1') and (blank = '0') and (color = "11") and (px = '0') else  -- color bg (after reverse+blink)
               x"000";

    process(clock)
    begin
        if rising_edge(clock) then
            rgb <= rgb_reg;
        end if;
    end process;
    
end behavior;


